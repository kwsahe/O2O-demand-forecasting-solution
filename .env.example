# 공공데이터포털 (data.go.kr) 인증키
# 1) 아파트매매 실거래 상세자료 (RTMSDataSvcAptTradeDev) - 거래 데이터 수집용
API_KEY=your_decoding_key_here

# 2) 공동주택 기본정보제공 서비스 - 단지 기본정보(단지코드, 세대수 등) 조회용
APT_BASIC_INFO_API_KEY=your_decoding_key_here

# 3) 전국인테리어업체표준데이터 (없으면 API_KEY로 폴백) - collect_interior_companies.py
INTERIOR_API_KEY=your_decoding_key_here

# 4) 소상공인시장진흥공단_상가(상권)정보 (없으면 API_KEY로 폴백) - collect_interior_stores.py
SBIZ_API_KEY=your_decoding_key_here

# 네이버 클라우드 플랫폼 Maps API 인증키 - 대시보드 지도 카드용
NAVER_MAP_CLIENT_ID=your_naver_map_client_id_here

# 로컬 Ollama 설정
OLLAMA_HOST=http://localhost:11434
CHAT_MODEL=qwen2.5:3b
